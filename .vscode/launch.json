{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Gitea Automation: Run",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/gitea.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Gitea Automation: Dry Run",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/gitea.py",
      "args": [
        "--dry-run"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
